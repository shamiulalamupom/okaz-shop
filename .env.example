# Common
NODE_ENV=development
CORS_ORIGIN=http://localhost:4200

# E2E tests: base URL the test suite hits (use 127.0.0.1 to avoid IPv6 resolution issues)
TEST_GATEWAY_URL=http://127.0.0.1:4000

# Shared internal service-to-service secret (used for stock reservation and event ingestion)
INTERNAL_SERVICE_SECRET=replace-with-a-long-random-internal-secret

# Gateway
GATEWAY_PORT=4000
GATEWAY_SERVICE_URL=http://localhost:4000
AUTH_SERVICE_URL=http://localhost:4001
PRODUCTS_SERVICE_URL=http://localhost:4002
STOCKS_SERVICE_URL=http://localhost:4003
ORDERS_SERVICE_URL=http://localhost:4004
NOTIFICATIONS_SERVICE_URL=http://localhost:4006
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=60000

# Auth Service
AUTH_PORT=4001
DATABASE_URL=replace-with-your-database-connection-string
AUTH_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
AUTH_JWT_ISSUER=okaz-auth
AUTH_JWT_AUDIENCE=okaz-api
AUTH_JWT_EXPIRES_IN_SECONDS=3600

# Dev-only seed fixture
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=Admin1234!

# Products Service
PRODUCTS_PORT=4002
MONGO_URI=mongodb://localhost:27017/okaz

# Stocks Service
STOCKS_PORT=4003
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/okaz_stocks?schema=public
STOCKS_REQUEST_MAX_BYTES=4096

# Orders Service
ORDERS_PORT=4004
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/okaz_orders?schema=public
# EVENTS_SINK_URL=http://localhost:4000
# NOTIFICATIONS_SERVICE_URL=http://localhost:4006
ORDERS_REQUEST_MAX_BYTES=8192

# Notifications Service (in-app order notifications)
NOTIFICATIONS_PORT=4006
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/okaz_notifications?schema=public
# AUTH_SERVICE_URL=http://localhost:4001
# EVENTS_SINK_URL=http://localhost:4000
NOTIFICATIONS_REQUEST_MAX_BYTES=4096

# Media Service (Cloudflare R2 image uploads + CDN)
MEDIA_PORT=4005
MEDIA_SERVICE_URL=http://localhost:4005
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/okaz_media?schema=public
MEDIA_MAX_UPLOAD_BYTES=5000000
MEDIA_ALLOWED_TYPES=image/jpeg,image/png,image/webp
# Cloudflare R2 (S3 API). Leave blank to run without real uploads (placeholder store).
R2_ENDPOINT=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=