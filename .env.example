# ---------------------------------------------------------------------------
# okaz-shop environment
#
# This file is the single source of truth for LOCAL (non-Docker) development,
# the seed scripts (`pnpm seed`) and the e2e tests (`pnpm test`).
#
# When running with Docker Compose the per-service values (ports, service URLs,
# DATABASE_URL) are set inside docker-compose.yml; only the SHARED SECRETS below
# are read from this file (the compose file references them as ${VAR}). So in
# practice, for Docker you only need to fill in the secrets section.
#
# Copy to `.env` and replace every "replace-with-..." placeholder.
# ---------------------------------------------------------------------------

# ===== Shared =====
NODE_ENV=development
# Browser origin allowed by the gateway CORS policy (Angular dev server / web container).
CORS_ORIGIN=http://localhost:4200

# ===== Shared secrets (also consumed by docker-compose.yml) =====
# Must be identical across every service that verifies JWTs / internal calls.
# AUTH_JWT_SECRET must be >= 32 chars, INTERNAL_SERVICE_SECRET >= 16 chars.
AUTH_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
AUTH_JWT_ISSUER=okaz-auth
AUTH_JWT_AUDIENCE=okaz-api
INTERNAL_SERVICE_SECRET=replace-with-a-long-random-internal-secret

# ===== Gateway (public entrypoint) =====
GATEWAY_PORT=4000
GATEWAY_SERVICE_URL=http://localhost:4000
AUTH_SERVICE_URL=http://localhost:4001
PRODUCTS_SERVICE_URL=http://localhost:4002
STOCKS_SERVICE_URL=http://localhost:4003
ORDERS_SERVICE_URL=http://localhost:4004
MEDIA_SERVICE_URL=http://localhost:4005
NOTIFICATIONS_SERVICE_URL=http://localhost:4006
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=60000

# ===== Auth service (PostgreSQL) =====
AUTH_PORT=4001
# Each Postgres-backed service owns its own logical database. When running the
# whole stack on the host from a single shell, every service reads the same
# DATABASE_URL key, so set/override it per service (e.g. export it before
# `pnpm dev:<service>`). Docker Compose already injects the right one per service.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/okaz_auth?schema=public
AUTH_JWT_EXPIRES_IN_SECONDS=3600

# Dev-only seed fixture (used by the seed scripts and e2e tests).
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=Admin1234!

# ===== Products service (MongoDB) =====
PRODUCTS_PORT=4002
MONGO_URI=mongodb://localhost:27017/okaz

# ===== Stocks service (PostgreSQL) =====
STOCKS_PORT=4003
# Host-only override (its own database):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/okaz_stocks?schema=public
STOCKS_REQUEST_MAX_BYTES=4096

# ===== Orders service (PostgreSQL) =====
ORDERS_PORT=4004
# Host-only override (its own database):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/okaz_orders?schema=public
ORDERS_REQUEST_MAX_BYTES=8192

# ===== Notifications service (PostgreSQL, in-app order notifications) =====
NOTIFICATIONS_PORT=4006
# Host-only override (its own database):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/okaz_notifications?schema=public
NOTIFICATIONS_REQUEST_MAX_BYTES=4096

# ===== Media service (PostgreSQL + Cloudflare R2 image uploads / CDN) =====
MEDIA_PORT=4005
# Host-only override (its own database):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/okaz_media?schema=public
MEDIA_MAX_UPLOAD_BYTES=5000000
MEDIA_ALLOWED_TYPES=image/jpeg,image/png,image/webp
# Cloudflare R2 (S3-compatible). Leave blank to run without real uploads
# (the service boots and presign fails with a clear error until these are set).
R2_ENDPOINT=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# ===== Tooling: seed scripts & e2e tests =====
# Gateway base URL the seed scripts and tests hit. Use 127.0.0.1 to avoid IPv6
# resolution issues. Keep these aligned with GATEWAY_SERVICE_URL above.
GATEWAY_URL=http://127.0.0.1:4000
TEST_GATEWAY_URL=http://127.0.0.1:4000
