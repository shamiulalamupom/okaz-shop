# Common
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Gateway
GATEWAY_PORT=4000
GATEWAY_SERVICE_URL=http://localhost:4000
AUTH_SERVICE_URL=http://localhost:4001
PRODUCTS_SERVICE_URL=http://localhost:4002
CART_SERVICE_URL=http://localhost:4003
ORDERS_SERVICE_URL=http://localhost:4004
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=60000

# Auth Service
AUTH_PORT=4001
DATABASE_URL=replace-with-your-database-connection-string
AUTH_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
AUTH_JWT_ISSUER=okaz-auth
AUTH_JWT_AUDIENCE=okaz-api
AUTH_JWT_EXPIRES_IN_SECONDS=3600

# Dev-only seed fixture
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=Admin1234!

# Products Service
PRODUCTS_PORT=4002
MONGO_URI=mongodb://localhost:27017/okaz

# Cart Service
CART_PORT=4003
CART_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/okaz_cart?schema=public
CART_REQUEST_MAX_BYTES=1024

# Orders Service
ORDERS_PORT=4004
ORDERS_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/okaz_orders?schema=public
ORDERS_REQUEST_MAX_BYTES=1024
DEFAULT_CURRENCY=usd
# Payment provider: "mock" (default, dev) or "stripe".
# When PAYMENT_PROVIDER=stripe, both STRIPE_* values are required.
PAYMENT_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=