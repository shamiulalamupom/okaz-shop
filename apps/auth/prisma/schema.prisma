generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  nom              String?
  prenom           String?
  email            String   @unique
  telephone        String?
  avatarUrl        String?
  avatarMediaId    String?
  passwordHash     String
  roles            String[] @default(["CUSTOMER"])
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  addresses        Address[]
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  label      String?
  line1      String
  city       String
  postalCode String
  country    String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
