{
  "name": "okaz-backend",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.12.2",
  "scripts": {
    "build": "pnpm -r build",
    "dev:auth": "pnpm --filter @okaz/auth dev",
    "dev:gateway": "pnpm --filter @okaz/gateway dev",
    "start:auth": "pnpm --filter @okaz/auth start",
    "start:gateway": "pnpm --filter @okaz/gateway start",
    "prisma:generate": "pnpm --filter @okaz/auth prisma:generate",
    "prisma:migrate": "pnpm --filter @okaz/auth prisma:migrate",
    "prisma:migrate:deploy": "pnpm --filter @okaz/auth prisma:migrate:deploy",
    "prisma:seed": "pnpm --filter @okaz/auth prisma:seed",
    "seed:products": "node scripts/seed-products.mjs",
    "test": "vitest run",
    "test:e2e": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.16.0",
    "@types/ws": "^8.5.12",
    "dotenv": "^17.3.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8",
    "ws": "^8.18.0"
  }
}
